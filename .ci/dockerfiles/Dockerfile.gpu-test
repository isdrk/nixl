# NIXL SLURM Test Environment
#
# GPU cluster testing container for SLURM-based test execution.
#
# Usage:
#   docker build -f .ci/dockerfiles/Dockerfile.slurm -t nixl-slurm .
#

ARG BASE_IMAGE=nvcr.io/nvidia/cuda-dl-base:25.10-cuda13.0-devel-ubuntu24.04

FROM ${BASE_IMAGE}

# Build arguments
ARG _UID=148069
ARG _GID=30
ARG NIXL_INSTALL_DIR
ARG NIXL_BUILD_DIR
ARG PRE_INSTALLED_ENV
ARG PRE_INSTALLED_NIXL_ENV
ARG PRE_INSTALLED_UCX_ENV
ARG UCX_VERSION=v1.20.x
ARG HAS_GPU=true
ARG WORKSPACE=/workspace/nixl


WORKDIR ${WORKSPACE}
COPY --chown="${_UID}":"${_GID}" . .

RUN .gitlab/build.sh ${NIXL_INSTALL_DIR}

ENTRYPOINT ["/bin/bash", "-c", "exec \"$@\"", "--"]

# Default command
CMD ["/bin/bash"]
